# PREDICT - Vehicle Intelligence Platform
# Copy this file to .env and fill in your values
# ALL values marked REQUIRED must be set before the app will start

# ========================
# DATABASE (REQUIRED)
# ========================
DATABASE_URL=postgresql+asyncpg://predict_admin:YOUR_PASSWORD@localhost:5432/predict

# ========================
# REDIS
# ========================
REDIS_URL=redis://localhost:6379/0

# ========================
# SECURITY (REQUIRED)
# ========================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY
ADMIN_API_KEY=CHANGE_ME_GENERATE_AN_ADMIN_KEY

# ========================
# EMAIL (REQUIRED for user registration)
# ========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@previlium.com
EMAIL_FROM_NAME=PREDICT

# ========================
# FIREBASE CLOUD MESSAGING (REQUIRED for push notifications)
# ========================
# Path to Firebase service account JSON
FCM_CREDENTIALS_PATH=config/firebase-credentials.json

# ========================
# BILLING - FATORA
# ========================
FATORA_API_KEY=
FATORA_WEBHOOK_SECRET=

# ========================
# MONITORING
# ========================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ========================
# LLM
# ========================
# Path to GGUF model file for local LLM
LLM_MODEL_PATH=models/gguf/qwen2.5-7b-instruct-q4_k_m.gguf
LLM_CONTEXT_SIZE=4096
LLM_GPU_LAYERS=0

# ========================
# EXTERNAL AI APIs (optional)
# ========================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ========================
# SERVER
# ========================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PUBLIC_API_URL=https://predict.previlium.com

# ========================
# CLOUDFLARE TUNNEL
# ========================
CLOUDFLARE_TUNNEL_TOKEN=
