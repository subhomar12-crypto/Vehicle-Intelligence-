# ===========================================
# Predict OBD - Git Ignore Configuration
# ===========================================

# -------------------------------------------
# API KEYS AND SECRETS (CRITICAL)
# -------------------------------------------
# Never commit API keys or credentials
api_keys.json
**/api_keys.json
!api_keys.template.json

# API key backup files
*_apikey.txt
*_APIKEY.txt
**/*_apikey.txt

# Credentials and secrets
credentials.json
secrets.json
*.secret
*.credentials
.env
.env.*
!.env.example

# -------------------------------------------
# APPLICATION DATA
# -------------------------------------------
# PredictData directory (user data)
PredictData/

# Legacy data directories
data/
config/api_keys.json

# Database files
*.db
*.sqlite
*.sqlite3

# -------------------------------------------
# PYTHON
# -------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

