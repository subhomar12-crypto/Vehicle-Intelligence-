PHASE: 1 – Database Layer
TASK: Verify predict/core/db/repositories/base.py
FILES:
  - C:\D Drive\Predict\predict\core\db\repositories\base.py
SUMMARY:
  BaseRepository(Generic[ModelT]) with async CRUD:
    - get_by_id(id_value: int) -> Optional[ModelT]
    - get_all(limit, offset) -> List[ModelT]
    - create(**kwargs) -> ModelT
    - update(instance, **kwargs) -> ModelT
    - delete(instance) -> None
    - count() -> int
